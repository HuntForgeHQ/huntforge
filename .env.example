# ══════════════════════════════════════════════════════════════
# HuntForge — Environment Variables Template
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
#
# HuntForge auto-loads .env on every run — no manual exporting.
# ══════════════════════════════════════════════════════════════

# --- AI Report Generation (Google Gemini) ---
GEMINI_API_KEY=""

# --- GitHub Dorking & Secret Scanning ---
GITHUB_TOKEN=""

# --- Shodan (Surface Intelligence) ---
SHODAN_API_KEY=""

# --- Censys (Surface Intelligence) ---
CENSYS_API_ID=""
CENSYS_API_SECRET=""

# --- WPScan (WordPress Vulnerability Scanner) ---
WPSCAN_API_TOKEN=""

# --- ProjectDiscovery Chaos (Subdomain Discovery) ---
CHAOS_KEY=""
