# ══════════════════════════════════════════════════════════════
# HuntForge — Environment Variables Template
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# HuntForge auto-loads .env on every run — no manual exporting.
# ══════════════════════════════════════════════════════════════

# --- AI (Ollama — local LLM, no API key needed) ---
# Default: Ollama running on localhost
OLLAMA_API_URL="http://localhost:11434/api/generate"
# If using Docker Compose, uncomment below instead:
# OLLAMA_API_URL="http://huntforge-ollama:11434/api/generate"
OLLAMA_MODEL="phi3:mini"

# --- GitHub Token (optional, for trufflehog/gitleaks) ---
GITHUB_TOKEN=""

# --- WPScan (optional, for WordPress scanning) ---
WPSCAN_API_TOKEN=""
